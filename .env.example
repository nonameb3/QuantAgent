# ── LLM providers (set the one you use) ─────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DASHSCOPE_API_KEY=sk-...          # Qwen / Alibaba Cloud
MINIMAX_API_KEY=...
MINIMAX_CN_API_KEY=...

# ── Telegram bot ─────────────────────────────────────────────────────────────
# Get a token from @BotFather, then message the bot to get your chat ID.
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=987654321

# ── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULER_SYMBOLS=BTC,ETH         # comma-separated symbols to watch
SCHEDULER_INTERVAL=15m            # 1m 5m 15m 30m 1h 4h 1d
SIGNAL_COOLDOWN_MINUTES=60        # min gap between signals per symbol
HEALTH_CHECK_MINUTES=120          # alert if bot is silent longer than this
